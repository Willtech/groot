#!/usr/bin/bash

# Install groot(1) man page

set -e

MANPAGE_SOURCE="groot.1"
MANPAGE_TARGET="/usr/share/man/man1/groot.1"

echo "Installing groot(1) man page..."

# Copy and compress
sudo install -Dm644 "$MANPAGE_SOURCE" "$MANPAGE_TARGET"
sudo gzip -f "$MANPAGE_TARGET"

# Update man database if mandb exists
if command -v mandb >/dev/null 2>&1; then
    echo "Updating man database..."
    sudo mandb >/dev/null 2>&1 || true
fi

echo "groot(1) installed successfully."
echo "Try: man groot"
