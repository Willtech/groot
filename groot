case "$1" in
    --shell-after)
        shift
        if [ $# -eq 0 ]; then
            exec sudo su -
        else
            # Arguments provided → run them as a root command
            cmd=$(printf ' %q' "$@")
            cmd=${cmd:1}
            bash -c "exec sudo $cmd"
            exec sudo su -
        fi
        ;;
    *)
        if [ $# -eq 0 ]; then
            exec sudo su -
        else
            exec sudo "$@"
        fi
        ;;
esac
