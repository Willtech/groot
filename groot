###############################################################################

VERSION="1.3.0"

# Flags
dry_run=false
shell_after=false

# Collect non-flag arguments
cmd_args=()

###############################################################################
# show_help — prints usage information
###############################################################################
show_help() {
            cat <<EOF
groot — a friendly sudo wrapper

Usage:
  groot                     Open a root login shell
  groot <cmd> [args]        Run a command as root
  groot --shell-after CMD   Run CMD as root, then open a root shell
  groot --dry-run CMD       Show what groot *would* run

Options:
  --help, -h                Show this help message
  --version                 Show version information
  --dry-run                 Do not execute anything; only show actions
  --shell-after             After running CMD, open a root login shell
EOF
}

###############################################################################
# show_version — prints version and authorship
###############################################################################
show_version() {
    cat <<EOF
groot version ${VERSION}
Author: Wills
Willtech — Swan Hill, Victoria
EOF
}

###############################################################################
# Parse flags (order-independent)
###############################################################################
for arg in "$@"; do
    case "$arg" in
        -h|--help)
            show_help
            exit 0
            ;;
        --version)
            show_version
            exit 0
            ;;
        --dry-run)
            dry_run=true
            ;;
        --shell-after)
            shell_after=true
            ;;
        *)
            cmd_args+=("$arg")
            ;;
    esac
done


###############################################################################
# Helper: print dry-run for normal mode
###############################################################################
dry_run_normal() {
    printf "[groot dry-run] sudo"
    for a in "${cmd_args[@]}"; do
        printf " %q" "$a"
    done
    printf "\n"
}

###############################################################################
# Helper: print dry-run for literal mode
###############################################################################
dry_run_literal() {
    literal=$(printf ' %q' "${cmd_args[@]}")
    literal=${literal:1}
    printf "[groot dry-run] sudo %s\n" "$literal"
    printf "[groot dry-run] (then would open a root login shell)\n"
}

###############################################################################
# EXECUTION LOGIC
###############################################################################

# Case 1: No command provided
if [ ${#cmd_args[@]} -eq 0 ]; then
    if $dry_run; then
        echo "[groot dry-run] sudo su -"
        $shell_after && echo "[groot dry-run] (then would open a root login shell)"
        exit 0
    fi
    exec sudo su -
fi

# Case 2: dry-run + shell-after
if $dry_run && $shell_after; then
    dry_run_literal
    exit 0
fi

# Case 3: dry-run only
if $dry_run; then
    dry_run_normal
    exit 0
fi

# Case 4: shell-after only
if $shell_after; then
    literal=$(printf ' %q' "${cmd_args[@]}")
    literal=${literal:1}
    bash -c "exec sudo $literal"
    exec sudo su -
fi

# Case 5: normal execution
exec sudo "${cmd_args[@]}"
